<Window x:Class="RevitBridge.AbutmentSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abutment Selection" Height="200" Width="300">
    <StackPanel>
        <TextBlock Text="Select an abutment to combine." Margin="10" FontWeight="Bold"/>
        <Button Content="A1 Abutment" Click="SelectA1_Click" Margin="10"/>
        <Button Content="A2 Abutment" Click="SelectA2_Click" Margin="10"/>
        <Button Content="Cancel" Click="Cancel_Click" Margin="10"/>
    </StackPanel>
</Window>