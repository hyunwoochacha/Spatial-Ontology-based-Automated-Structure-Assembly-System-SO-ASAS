<Window x:Class="RevitBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RevitBridge"
        Title="Bridge Structure Arrangement"
        Height="700" Width="1000">

    <!-- Window Resources -->
    <Window.Resources>
        <!-- Copied from UserControl1.xaml -->
        <!-- Color Resources -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#FF2C2F33"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FFFFC107"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#FF23272A"/>
        <SolidColorBrush x:Key="DisabledTextColor" Color="#FF888888"/>

        <!-- Button Style -->
        <Style TargetType="Button" x:Key="AccentButtonStyle">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBlock Style -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>
    </Window.Resources>

    <!-- Main Layout -->
    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="194*"/>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="313*"/>
            <ColumnDefinition Width="198*"/>
            <ColumnDefinition Width="245*"/>
        </Grid.ColumnDefinitions>

        <!-- Main Content Start -->
        <Grid Margin="0,30,0,0" Grid.ColumnSpan="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <!-- Sidebar -->
                <ColumnDefinition Width="*"/>
                <!-- Main Content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar Start -->
            <StackPanel Background="{StaticResource CardBackgroundColor}" Grid.Column="0">
                <!-- Header -->
                <TextBlock Text="MENU" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextColor}" Margin="10"/>

                <!-- Button List -->
                <Button Content="🏠 Home" Style="{StaticResource AccentButtonStyle}" Click="HomeButton_Click"/>
                <Button Content="Bridge" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Opacity="0.5"/>
                <Button Content="Road (In Development)" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Opacity="0.5"/>
                <Button Content="Railway (In Development)" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Opacity="0.5"/>

                <!-- Video Area -->
                <Border Background="#FF1E1E1E" CornerRadius="10" Height="508">
                    <MediaElement x:Name="VideoPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" />
                </Border>
                <Button Content="Play Video" Style="{StaticResource AccentButtonStyle}" Click="PlayVideo_Click"/>
            </StackPanel>
            <!-- Sidebar End -->

            <!-- Main Content Start -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="BRIDGE STRUCTURE" FontWeight="Bold" FontSize="24"
                           HorizontalAlignment="Center" Margin="10" Grid.Row="0"/>

                <!-- Content Area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- TreeView Area -->
                        <ColumnDefinition Width="2*"/>
                        <!-- Detail Area -->
                    </Grid.ColumnDefinitions>

                    <!-- TreeView Area Start -->
                    <Border Margin="10,168,10,10" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="5" Grid.Column="0" Grid.ColumnSpan="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="329" VerticalAlignment="Bottom" Margin="0,0,9,0">
                            <TreeView Name="MainTreeView" SelectedItemChanged="MainTreeView_SelectedItemChanged" Height="432" RenderTransformOrigin="0.5,0.5" Width="506">
                                <TreeView.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform AngleX="-0.26"/>
                                        <RotateTransform/>
                                        <TranslateTransform X="-0.424"/>
                                    </TransformGroup>
                                </TreeView.RenderTransform>
                                <TreeViewItem Header="Bridge" IsExpanded="True" RenderTransformOrigin="0.5,0.5">
                                    <TreeViewItem.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform AngleX="-1.122"/>
                                            <RotateTransform/>
                                            <TranslateTransform X="1.41"/>
                                        </TransformGroup>
                                    </TreeViewItem.RenderTransform>
                                    <TreeViewItem Header="Rigid Frame Bridge" IsExpanded="True">
                                        <TreeViewItem Header="Structure Placement">
                                            <TreeViewItem Header="Pier - Superstructure - Pier" Tag="Structure_Pier_Superstructure_Pier"/>
                                            <TreeViewItem Header="Abutment - Superstructure - Abutment" Tag="Structure_Abutment_Superstructure_Abutment"/>
                                            <TreeViewItem Header="Pier - Superstructure - Abutment" Tag="Structure_Pier_Superstructure_Abutment"/>
                                            <TreeViewItem Header="Abutment - Superstructure - Pier" Tag="Structure_Abutment_Superstructure_Pier"/>
                                        </TreeViewItem>
                                        <TreeViewItem Header="Object Placement">
                                            <TreeViewItem Header="Place Pier" Tag="Object_Pier"/>
                                            <TreeViewItem Header="Place Abutment" Tag="Object_Abutment"/>
                                            <TreeViewItem Header="Place Superstructure" Tag="Object_Superstructure"/>
                                        </TreeViewItem>
                                        <TreeViewItem Header="Combine All Elements" Tag="CombineAll"/>
                                        <TreeViewItem Header="Cancel" Tag="Cancel"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="T-type Bridge (Coming Soon)" Foreground="{StaticResource DisabledTextColor}"/>
                                    <TreeViewItem Header="Cable-stayed Bridge (Coming Soon)" Foreground="{StaticResource DisabledTextColor}"/>
                                    <TreeViewItem Header="Suspension Bridge (Coming Soon)" Foreground="{StaticResource DisabledTextColor}"/>
                                </TreeViewItem>
                            </TreeView>
                        </ScrollViewer>
                    </Border>
                    <!-- TreeView Area End -->

                    <!-- Detail Area Start -->
                    <StackPanel Margin="103,10,103,10" Grid.ColumnSpan="2">
                        <TextBlock FontWeight="Bold" FontSize="18" Text="BRIDGE ONTOLOGY"/>
                        <TextBlock Margin="0,10,0,20" Text="Select the library ontology file (.ttl file)."/>
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Label Content="TTL File:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                            <TextBox x:Name="TtlFilePathTextBox" Width="200" Margin="5"/>
                            <Button Content="Browse" 
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="BrowseTtlFile_Click"/>
                        </StackPanel>
                        <Button Content="Run" Style="{StaticResource AccentButtonStyle}" Click="GetStartedButton_Click"/>
                    </StackPanel>
                    <!-- Detail Area End -->
                </Grid>
            </Grid>
            <!-- Main Content End -->
        </Grid>

        <!-- Main Content End -->
    </Grid>
</Window>
