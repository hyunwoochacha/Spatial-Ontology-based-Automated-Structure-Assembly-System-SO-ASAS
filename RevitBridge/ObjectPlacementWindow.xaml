<Window x:Class="RevitBridge.ObjectPlacementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Object Placement" Height="400" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="17*"/>
            <ColumnDefinition Width="8*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0" Grid.ColumnSpan="2">
            <Button Content="Place Pier" Click="PlacePier_Click" Margin="10" Width="300" Height="40"/>
            <Button Content="Place Abutment" Click="PlaceAbutment_Click" Margin="10" Width="300" Height="40"/>
            <Button Content="Place Superstructure" Click="PlaceSuperstructure_Click" Margin="10" Width="300" Height="40"/>

        </StackPanel>
    </Grid>
</Window>