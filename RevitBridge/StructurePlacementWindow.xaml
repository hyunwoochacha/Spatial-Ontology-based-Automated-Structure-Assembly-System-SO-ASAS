<Window x:Class="RevitBridge.StructurePlacementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Structure Placement" Height="400" Width="400">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <Button Content="Abutment - Superstructure - Abutment" Click="AbutmentSuperstructureAbutment_Click" Margin="10" Width="300" Height="40"/>
            <Button Content="Abutment - Superstructure - Pier" Click="AbutmentSuperstructurePier_Click" Margin="10" Width="300" Height="40"/>
            <Button Content="Pier - Superstructure - Abutment" Click="PierSuperstructureAbutment_Click" Margin="10" Width="300" Height="40"/>
            <Button Content="Pier - Superstructure - Pier" Click="PierSuperstructurePier_Click" Margin="10" Width="300" Height="40"/>
        </StackPanel>
    </Grid>
</Window>