#################################################################
#    Individuals - SuperStructure
#################################################################

bso:SuperStructure_Instance rdf:type owl:NamedIndividual ,
                                     bso:SuperStructure ;
                            bso:isPartOf bso:Bridge_Instance .

bso:Slab_Instance rdf:type owl:NamedIndividual ,
                          bso:Slab ;
                 bso:isPartOf bso:SuperStructure_Instance ;
                 bso:material "Concrete" ;
                 bso:name "Slab" .

bso:Protectivewall_Left_Instance rdf:type owl:NamedIndividual ,
                              bso:Protectivewall ;
                     bso:isPartOf bso:SuperStructure_Instance ;
                     bso:isPutOn bso:Slab_Instance ;
                     bso:material "Concrete" ;
                     bso:name "ProtectiveWall_Left" .

bso:Protectivewall_Right_Instance rdf:type owl:NamedIndividual ,
                              bso:Protectivewall ;
                     bso:isPartOf bso:SuperStructure_Instance ;
                     bso:isPutOn bso:Slab_Instance ;
                     bso:material "Concrete" ;
                     bso:name "ProtectiveWall_Right" .
