#################################################################
#    Individuals - Abutment A1
#################################################################

###  http://example.org/A1_AbutmentFooting_Instance
ex:A1_AbutmentFooting_Instance rdf:type owl:NamedIndividual ,
                                      ex:AbutmentFooting ;
                             ex:isPartOf ex:Bridge_Instance ;
                             ex:material "Concrete" ;
                             ex:name "A1_Abutment_Footing" ;
                             ex:staLocation "sta 0" .


###  http://example.org/A1_AbutmentFoundation_Instance
ex:A1_AbutmentFoundation_Instance rdf:type owl:NamedIndividual ,
                                         ex:AbutmentFoundation ;
                                ex:isAttachedTo ex:A1_AbutmentFooting_Instance ;
                                ex:isPartOf ex:Bridge_Instance ;
                                ex:material "Concrete" ;
                                ex:name "A1_Abutment_Foundation" ;
                                ex:staLocation "sta 0" .


###  http://example.org/A1_AbutmentWall_Instance
ex:A1_AbutmentWall_Instance rdf:type owl:NamedIndividual ,
                                  ex:AbutmentWall ;
                         ex:isAttachedTo ex:A1_AbutmentFoundation_Instance ;
                         ex:isPartOf ex:Bridge_Instance ;
                         ex:isBearingWith ex:Slab_Instance ;
                         ex:material "Concrete" ;
                         ex:name "A1_Abutment_Wall" ;
                         ex:staLocation "sta 0" .


###  http://example.org/A1_AbutmentWingWall_Left_Instance
ex:A1_AbutmentWingWall_Left_Instance rdf:type owl:NamedIndividual ,
                                          ex:AbutmentWingWall ;
                                  ex:isAdjacentOf ex:A1_AbutmentWall_Instance ;
                                  ex:isAttachedTo ex:A1_AbutmentFoundation_Instance ;
                                  ex:isPartOf ex:Bridge_Instance ;
                                  ex:material "Concrete" ;
                                  ex:name "A1_Abutment_WingWall_Left" ;
                                  ex:staLocation "sta 0" .


###  http://example.org/A1_AbutmentWingWall_Right_Instance
ex:A1_AbutmentWingWall_Right_Instance rdf:type owl:NamedIndividual ,
                                           ex:AbutmentWingWall ;
                                   ex:isAdjacentOf ex:A1_AbutmentWall_Instance ;
                                   ex:isAttachedTo ex:A1_AbutmentFoundation_Instance ;
                                   ex:isPartOf ex:Bridge_Instance ;
                                   ex:material "Concrete" ;
                                   ex:name "A1_Abutment_WingWall_Right" ;
                                   ex:staLocation "sta 0" .


###  http://example.org/A1_AbutmentCap_Instance
ex:A1_AbutmentCap_Instance rdf:type owl:NamedIndividual ,
                                 ex:AbutmentCap ;
                        ex:isAttachedTo ex:A1_AbutmentWall_Instance ;
                        ex:isPartOf ex:Bridge_Instance ;
                        ex:material "Concrete" ;
                        ex:name "A1_Abutment_Cap" ;
                        ex:staLocation "sta 0" .


