#################################################################
#    Individuals - Superstructure
#################################################################

###  http://example.org/SuperStructure_Instance
ex:SuperStructure_Instance rdf:type owl:NamedIndividual ,
                                     ex:SuperStructure ;
                            ex:isPartOf ex:Bridge_Instance ;
                            ex:material "Concrete" ;
                            ex:name "Main SuperStructure" ;
                            ex:staLocation "sta 1+000" .

###  http://example.org/Slab_Instance
ex:Slab_Instance rdf:type owl:NamedIndividual ,
                          ex:Slab ;
                 ex:isPartOf ex:SuperStructure_Instance ;
                 ex:material "Concrete" ;
                 ex:name "Slab" ;
                 ex:staLocation "sta 1+000" .

###  http://example.org/Protectivewall_Left_Instance
ex:Protectivewall_Left_Instance rdf:type owl:NamedIndividual ,
                              ex:Protectivewall ;
                     ex:isPartOf ex:SuperStructure_Instance ;
                     ex:isPuttingOn ex:Slab_Instance ;
                     ex:material "Concrete" ;
                     ex:name "ProtectiveWall_Left" ;
                     ex:staLocation "sta 1+000" .

###  http://example.org/Protectivewall_Right_Instance
ex:Protectivewall_Right_Instance rdf:type owl:NamedIndividual ,
                              ex:Protectivewall ;
                     ex:isPartOf ex:SuperStructure_Instance ;
                     ex:isPuttingOn ex:Slab_Instance ;
                     ex:material "Concrete" ;
                     ex:name "ProtectiveWall_Right" ;
                     ex:staLocation "sta 1+000" .
