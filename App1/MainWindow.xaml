<Window x:Class="BridgeApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bridge Structure Arrangement" 
        Height="800" Width="1200"
        WindowStyle="None"
        Background="#FF2C2F33">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FF2C2F33"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FFFFC107"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#FF23272A"/>
    </Window.Resources>

    <Grid>
        <!-- 타이틀바 -->
        <Grid Height="30" VerticalAlignment="Top" Background="#FF1E2124">
            <TextBlock Text="Bridge Structure Arrangement" 
                     Foreground="White" 
                     Margin="10,0,0,0" 
                     VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" 
                      HorizontalAlignment="Right">
                <Button Content="─" Width="45" Click="MinimizeButton_Click"/>
                <Button Content="□" Width="45" Click="MaximizeButton_Click"/>
                <Button Content="×" Width="45" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- 메인 콘텐츠 -->
        <Grid Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 패널 (영상 영역) -->
            <Border Grid.Column="0" 
                    Background="#FF23272A" 
                    Margin="10">
                <MediaElement x:Name="videoPlayer" 
                            LoadedBehavior="Manual"
                            UnloadedBehavior="Stop"/>
            </Border>

            <!-- 오른쪽 패널 -->
            <Grid Grid.Column="1">
                <!-- 여기에 기존 UserControl1의 내용을 배치 -->
            </Grid>
        </Grid>
    </Grid>
</Window>